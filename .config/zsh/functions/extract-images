#!/bin/zsh
# Пример функции, которая извлекает все изображения из XML/HTML файла.
#
# Использование:
#   autoload -Uz extract-images
#   local -a reply=()
#   extract-images <file>
#   print -c -- $reply
#

# Как и любая shell-команда, функция может явно вернуть только целое число
# (код выхода), где 0 означает успех, а другие значения — различные ошибки.
# Для возврата других значений принято использовать $REPLY или $reply.
# Чтобы вернуть одну строку, число или float, присваивайте значение в $REPLY.
# Чтобы вернуть (ассоциативный) массив строк, присваивайте в $reply.
# Функция должна только _присваивать_ этим переменным; объявлять переменные
# и управлять их областью видимости должен вызывающий код.
# Для более гибкого API можно позволить вызывающему указать имена переменных,
# в которые функция запишет результаты.


# `emulate zsh` сбрасывает опции, влияющие на скрипт, к значениям zsh.
# `-L` делает этот эффект локальным для функции и ее потомков.
# `-o ...` задает опцию shell.
# https://zsh.sourceforge.io/Doc/Release/Invocation.html#Invocation
emulate -L zsh -o EXTENDED_GLOB
# EXTENDED_GLOB дает доступ к дополнительным шаблонам сопоставления,
# которые нужны ниже.

# Примечание: `emulate bash` работает не так, как можно ожидать, потому что
# `emulate` не знает оболочку 'bash'. Включится эмуляция `sh`, так как 'bash'
# заканчивается на 'sh'. Если нужна совместимость с bash, попробуйте `emulate ksh`.

# Указываем разделители полей для ${=...}, используемого ниже.
# +h сохраняет "специальность" $IFS для нашей локальной версии переменной.
# https://zsh.sourceforge.io/Doc/Release/Parameters.html#Parameters-Used-By-The-Shell
# https://zsh.sourceforge.io/Doc/Release/Shell-Builtin-Commands.html#index-typeset
local +h IFS='<>"()'

# < $1 перенаправляет содержимое файла $1 на стандартный вывод.
# $( ... ) захватывает стандартный вывод в строку.
# "..." сохраняет все пробелы, включая переносы строк.
# ${=...} разбивает строку по $IFS.
# reply=( ... ) помещает получившиеся строки в массив $reply.
reply=( ${="$( < $1 )"} )

#                  [@]:  для каждой строки,
#                  (M):  оставить наидлиннейшую подстроку ("match"), которая
#                   ##:  начинается с начала строки и
#  *.(gif|jpg|png|svg):  заканчивается на .gif, .jpg, .png или .svg.
# Если такой подстроки нет, вся строка отбрасывается (так как выражение не
# обернуто в "двойные кавычки").
# https://zsh.sourceforge.io/Doc/Release/Expansion.html#Parameter-Expansion
reply=( ${(M)reply[@]##*.(gif|jpg|png|svg)} )

#          [@]:  для каждой строки,
#           ##:  удалить в начале строки
# [[:blank:]]#:  все пробелы и табы (если есть).
#                Затем в итоговом массиве строк:
#          (u):  удалить дубликаты ("unique") и
#          (i):  отсортировать без учета регистра.
reply=( ${(ui)reply[@]##[[:blank:]]#} )

# Вернуть 0 (успех), если в $reply есть элементы.
# Иначе вернуть 1 (ошибка).
(( $#reply ))

# (( ... )) создает арифметическое выражение.
# Если выражение вычисляется в 0 (ложь), возвращается 1 (ошибка).
# Если выражение вычисляется в любое другое значение (истина), возвращается
# 0 (успех).
# https://zsh.sourceforge.io/Doc/Release/Arithmetic-Evaluation.html

# Функция всегда возвращает код выхода последнего выражения.
