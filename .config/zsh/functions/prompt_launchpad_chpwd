#!/bin/zsh
# Вместо вывода текущей директории в каждом prompt показываем ее только при
# смене каталога через hook-функцию.

RPS1=   # Очищаем правую часть prompt; см. следующий раздел.

# Просим Zsh Line Editor обеспечить корректный визуальный вид prompt и строки
# до и после нашего вывода.
zle -I

# Флаг -P обрабатывает escape-коды prompt.
print -P "\n%F{12}%~%f"   # 12 — ярко-синий.
