#!/bin/zsh
# Настройка темы prompt.


##
# Основной prompt
#

# Escape-коды prompt
#      %F{<x>}:  установить цвет текста. <x> может быть именем одного из 8
#                стандартных цветов, числом от 0 до 255 или hex-цветом
#                (если терминал поддерживает). См. также
#                https://en.wikipedia.org/wiki/ANSI_escape_code#Colors
#           %f:  сбросить цвет текста к значению по умолчанию
#           %~:  текущая директория в сокращенном виде (~)
#           %#:  если пользователь root, то '#', иначе '%'
# %(?,<a>,<b>):  если последний код выхода 0, берется <a>, иначе <b>
# https://zsh.sourceforge.io/Doc/Release/Prompt-Expansion.html
PS1="%F{%(?,10,9)}%#%f "  # 10 — ярко-зеленый; 9 — ярко-красный.

# Строки в "двойных кавычках" похожи на template strings:
# внутри работают $подстановки, которые заменяются значениями переменных.
# Строки в 'одинарных кавычках' — литералы.
# Они всегда вычисляются в точный набор символов, который вы видите.


# Устанавливаем наши hook-функции chpwd и precmd.
# https://zsh.sourceforge.io/Doc/Release/Functions.html#Hook-Functions
# -U говорит autoload не разворачивать алиасы внутри функции.
# -z сообщает autoload, что файл функции написан в стандартном стиле Zsh.
# Обычно это не обязательно, но так надежнее.
autoload -Uz add-zsh-hook
local hook=
for hook in chpwd precmd; do
  add-zsh-hook $hook prompt_launchpad_$hook
done
# add-zsh-hook может autoload'ить наши функции по имени, потому что в 04-env.zsh
# мы добавили их родительскую директорию в $fpath.

prompt_launchpad_chpwd  # Вызываем один раз перед первым prompt.


##
# Continuation prompt
#
# Этот prompt показывается, если после Enter в командной строке остались
# незакрытые конструкции shell, например строка без закрывающей кавычки
# или цикл `for` без завершающего `done`.

PS2=  # Убираем левую часть, чтобы было проще копировать код из терминала.
RPS2="%F{11}%^%f"  # %^ показывает, какие конструкции все еще не закрыты.
# 11 — ярко-желтый.


##
# Опции
#

# Автоматически очищать правую часть prompt после Enter.
# Экран становится менее шумным, и код проще копировать.
setopt TRANSIENT_RPROMPT

# Если это не SSH-сессия, убираем внешний отступ у правой части prompt.
[[ -v SSH_CONNECTION ]] ||
    ZLE_RPROMPT_INDENT=0
