#!/bin/zsh

#
# Этот файл `~/.zshrc` загружается zsh для каждой интерактивной сессии shell.
#

# Приводим ZDOTDIR к единому пути, чтобы модули всегда искались в ~/.config/zsh.
export ZDOTDIR="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"

# Явная ошибка для случая неполной установки/синхронизации.
if [[ ! -d "$ZDOTDIR/rc.d" ]]; then
  print -u2 -- "zsh: error: missing $ZDOTDIR/rc.d. Sync <repo>/.config/zsh to ~/.config/zsh."
  return 1 2>/dev/null || exit 1
fi

# Конструкция ниже — это анонимная функция в терминах Zsh (в других языках ее
# можно назвать lambda или scope-функцией). Она вызывается сразу с переданными
# аргументами и затем уничтожается.
# Это позволяет использовать локальную область видимости в dotfiles.
() {
  # `local` задает область видимости переменной в этой функции и ее потомках.
  local file=

  # Загружаем все файлы в rc.d вида <число>-*.zsh.
  # (n) сортирует результат в числовом порядке.
  # <0->  соответствует любому целому >= 0.
  #  <->  то же, что и <0->
  # <0-9> соответствует любому целому >= 0 и <= 9.
  #  <-9> то же, что и <0-9>
  # См. https://zsh.sourceforge.io/Doc/Release/Expansion.html#Glob-Operators
  for file in "$ZDOTDIR"/rc.d/<->-*.zsh(n); do
    . "$file"   # `.` аналогичен `source`, но не ищет файл в $path.
  done
} "$@"

# $@ разворачивается во все аргументы, переданные в текущий контекст (здесь —
# в сам `zsh`).
# "Двойные кавычки" гарантируют сохранение пустых аргументов ''.
# Передавать "$@" — хорошая практика: это предотвращает много тонких багов.
